---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Rapport de performance — Lumerank">
  <div id="report">
    <div class="top-progress" id="top-progress"></div>
    <header class="header">
      <div class="header-inner">
        <div class="logo">
          <img src="/Lumerank-logo-blanc-02.png" alt="Lumerank" class="logo-header" />
        </div>
        <p class="subtitle">Rapport de performance</p>
        <h1 class="client-name" id="client-name">Votre aperçu</h1>
        <p class="target-url" id="target-url"></p>
        <button class="view-apercu-btn js-view-apercu" type="button">← Voir l'aperçu</button>
      </div>
    </header>

    <main class="main">
      <section class="scores" aria-live="polite">
        <h2 class="section-title">Scores Lighthouse</h2>
        <div class="loader" id="loader">
          <div class="loader-logo">
            <img src="/Lumerank-logo-blanc-02.png" alt="Lumerank" class="logo-header" />
          </div>
          <p class="loader-text">
            Analyse en cours<span class="dots"><span class="dot dot-1"></span><span class="dot dot-2"></span><span class="dot dot-3"></span></span>
          </p>
          <p class="loader-sub">Cela peut prendre 5 à 10 secondes</p>
          <p class="loader-attribution">Scores calculés par Google PageSpeed Insights</p>
        </div>
        <div class="score-grid" id="score-grid"></div>
        <p class="error-message" id="error-message" hidden>
          Impossible de charger les scores — réessayez dans quelques instants.
        </p>
      </section>

      <section class="metrics">
        <h2 class="section-title">Métriques clés</h2>
        <div class="metrics-row" id="metrics-row">
          <div class="metric-card">
            <p class="metric-label">Temps de chargement</p>
            <p class="metric-value" id="metric-interactive">—</p>
            <p class="metric-desc">Temps pour que la page devienne interactive</p>
          </div>
          <div class="metric-card">
            <p class="metric-label">First Contentful Paint</p>
            <p class="metric-value" id="metric-fcp">—</p>
            <p class="metric-desc">Premier contenu affiché à l'écran</p>
          </div>
          <div class="metric-card">
            <p class="metric-label">Speed Index</p>
            <p class="metric-value" id="metric-si">—</p>
            <p class="metric-desc">Vitesse d'affichage visuel de la page</p>
          </div>
        </div>
      </section>

      <section class="comparison">
        <h2 class="section-title">La différence Lumerank</h2>
        <div class="comparison-card">
          <div class="comparison-side">
            <p class="comparison-label">Site WordPress moyen</p>
            <div class="bar-track">
              <div class="bar-fill bar-red" style="width: 35%"></div>
            </div>
            <p class="comparison-score">35/100</p>
          </div>
          <div class="comparison-side">
            <p class="comparison-label">Votre aperçu Lumerank</p>
            <div class="bar-track">
              <div class="bar-fill bar-green" id="comparison-fill" style="width: 0%"></div>
            </div>
            <p class="comparison-score" id="comparison-score">—/100</p>
          </div>
        </div>
      </section>
    </main>

    <section class="share">
      <div class="share-inner">
        <h2 class="share-title">Prêt à mettre ce site en ligne ?</h2>
        <div class="share-actions">
          <a
            class="whatsapp-btn"
            id="whatsapp-btn"
            href="https://wa.me/33753424756?text=Bonjour%20Lumerank%2C%20je%20veux%20mettre%20mon%20site%20en%20ligne%20!"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
              <path d="M12.001 2c-5.514 0-9.99 4.476-9.99 9.99 0 1.76.463 3.48 1.34 4.99L2 22l5.15-1.336a9.96 9.96 0 0 0 4.85 1.235h.004c5.514 0 9.99-4.476 9.99-9.989 0-2.669-1.037-5.176-2.924-7.062A9.933 9.933 0 0 0 12.001 2zm5.878 15.867a8.29 8.29 0 0 1-5.877 2.435h-.003a8.31 8.31 0 0 1-4.233-1.16l-.304-.18-3.058.793.816-2.981-.198-.306a8.264 8.264 0 0 1-1.267-4.408c0-4.583 3.732-8.313 8.318-8.313a8.26 8.26 0 0 1 5.878 2.44 8.257 8.257 0 0 1 2.436 5.877 8.302 8.302 0 0 1-2.508 5.803z"></path>
            </svg>
            <span>Discuter sur WhatsApp</span>
          </a>
          <button class="share-apercu-btn js-view-apercu" type="button">← Voir l'aperçu</button>
        </div>
        <p class="share-footer">go.lumerank.fr — Aperçu gratuit en 24h</p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .header {
    background: #0a0a0a;
    color: #fff;
    padding: 3rem 1.5rem 3.5rem;
  }

  .header-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .logo {
    margin-bottom: 1.5rem;
  }

  .logo-header {
    height: 32px;
    width: auto;
  }

  .subtitle {
    font-size: 0.85rem;
    color: #a3a3a3;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .client-name {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    margin-bottom: 0.5rem;
  }

  .target-url {
    font-size: 0.85rem;
    color: #737373;
  }

  .view-apercu-btn {
    margin-top: 1rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.78rem;
    padding: 5px 12px;
    border-radius: 999px;
    font-family: inherit;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .view-apercu-btn:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  .section-title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .scores {
    margin-bottom: 3rem;
  }

  .score-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 400px;
    margin: 0 auto;
  }

  /*
    :global() is required here: score cards are injected at runtime via
    innerHTML (see buildScoreCard in the script below), so Astro's scoped
    CSS attribute never gets attached to them — unscoped rules are the only
    ones that reach dynamically-created markup.
  */
  :global(.score-card) {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    max-width: 160px;
    width: 100%;
    margin: 0 auto;
  }

  :global(.score-ring) {
    width: 100%;
    height: auto;
    max-width: 120px;
    display: block;
    margin: 0 auto;
  }

  :global(.score-label) {
    font-size: 0.9rem;
    font-weight: 700;
    color: #404040;
  }

  .loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 1rem;
    text-align: center;
  }

  /*
    [hidden] is a user-agent-origin rule (display:none), which the cascade
    always ranks below author-origin rules regardless of specificity — so
    without this override, the `.loader { display: flex }` rule above wins
    even after JS sets the hidden attribute, and the loader never visually
    disappears.
  */
  .loader[hidden] {
    display: none;
  }

  .loader-logo {
    background: #0a0a0a;
    padding: 6px 14px;
    border-radius: 8px;
    display: inline-block;
  }

  .loader-logo .logo-header {
    height: 24px;
    width: auto;
  }

  .loader-text {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 1rem;
    font-weight: 700;
    color: #404040;
  }

  .dots {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ffc700;
    opacity: 0;
  }

  .dot-1 {
    animation: dotFlash 1.1s infinite 0s;
  }

  .dot-2 {
    animation: dotFlash 1.1s infinite 0.15s;
  }

  .dot-3 {
    animation: dotFlash 1.1s infinite 0.3s;
  }

  @keyframes dotFlash {
    0%,
    80%,
    100% {
      opacity: 0.25;
      transform: scale(0.7);
    }
    40% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  .loader-sub {
    font-size: 0.8rem;
    color: #a3a3a3;
  }

  .loader-attribution {
    font-size: 0.72rem;
    color: #9ca3af;
    margin-top: 6px;
    font-style: italic;
  }

  .top-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: #ffc700;
    z-index: 9999;
    animation: progressFill 8s ease-out forwards;
  }

  .top-progress.done {
    animation: none;
    width: 100%;
    transition: width 0.3s ease, opacity 0.4s ease 0.3s;
    opacity: 0;
  }

  @keyframes progressFill {
    from {
      width: 0%;
    }
    to {
      width: 85%;
    }
  }

  .error-message {
    margin-top: 1rem;
    color: #dc2626;
    font-size: 0.9rem;
    font-weight: 700;
    text-align: center;
  }

  .metrics {
    margin-bottom: 3rem;
  }

  .metrics-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .metric-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.25rem;
  }

  .metric-label {
    font-size: 0.8rem;
    color: #737373;
    margin-bottom: 0.4rem;
  }

  .metric-value {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: "Plus Jakarta Sans", sans-serif;
    margin-bottom: 0.4rem;
  }

  .metric-desc {
    font-size: 0.78rem;
    color: #a3a3a3;
  }

  .comparison-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .comparison-label {
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .bar-track {
    width: 100%;
    height: 10px;
    border-radius: 999px;
    background: #f3f4f6;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.8s ease;
  }

  .bar-red {
    background: #dc2626;
  }

  .bar-green {
    background: #15803d;
  }

  .comparison-score {
    font-size: 1.1rem;
    font-weight: 800;
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .share {
    background: #ffc700;
    padding: 3rem 1.5rem;
  }

  .share-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .share-title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #0a0a0a;
    margin-bottom: 1.5rem;
  }

  .share-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #0a0a0a;
    color: #fff;
    font-weight: 700;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .whatsapp-btn:hover {
    background: #1a1a1a;
    transform: translateY(-1px);
  }

  .share-apercu-btn {
    background: transparent;
    border: 1px solid rgba(10, 10, 10, 0.3);
    color: rgba(10, 10, 10, 0.75);
    font-size: 0.78rem;
    padding: 5px 12px;
    border-radius: 999px;
    font-family: inherit;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .share-apercu-btn:hover {
    border-color: rgba(10, 10, 10, 0.6);
    color: #0a0a0a;
  }

  .share-footer {
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: #4a3d00;
  }

  @media (max-width: 560px) {
    .score-grid {
      gap: 0.75rem;
      max-width: 320px;
    }

    :global(.score-card) {
      padding: 1rem;
      max-width: 130px;
    }

    :global(.score-ring) {
      max-width: 100px;
    }

    .comparison-card {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function formatClientName(slug: string): string {
    return slug
      .replace(/-/g, " ")
      .replace(/\b\w/g, (c) => c.toUpperCase());
  }

  function scoreColor(score: number): string {
    if (score >= 90) return "#15803D";
    if (score >= 50) return "#D97706";
    return "#DC2626";
  }

  function buildScoreCard(label: string, score: number | null): string {
    const value = score === null ? 0 : Math.round(score);
    const color = score === null ? "#a3a3a3" : scoreColor(value);
    const radius = 52;
    const circumference = 2 * Math.PI * radius;
    const offset = circumference * (1 - value / 100);

    return `
      <div class="score-card">
        <svg class="score-ring" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="${radius}" fill="none" stroke="#e5e7eb" stroke-width="10" />
          <circle
            cx="60" cy="60" r="${radius}" fill="none"
            stroke="${color}" stroke-width="10"
            stroke-linecap="round"
            stroke-dasharray="${circumference}"
            stroke-dashoffset="${offset}"
            transform="rotate(-90 60 60)"
            style="transition: stroke-dashoffset 1s ease;"
          />
          <text
            x="60" y="61" text-anchor="middle" dominant-baseline="middle"
            font-size="24" font-weight="800" font-family="'Plus Jakarta Sans', sans-serif"
            fill="${color}"
          >${score === null ? "—" : value}</text>
        </svg>
        <p class="score-label">${label}</p>
      </div>
    `;
  }

  function finishProgressBar() {
    const bar = document.getElementById("top-progress");
    if (bar) bar.classList.add("done");
  }

  function hideLoader() {
    const loader = document.getElementById("loader");
    if (loader) loader.hidden = true;
  }

  function showError() {
    const errorEl = document.getElementById("error-message");
    const grid = document.getElementById("score-grid");
    hideLoader();
    finishProgressBar();
    if (errorEl) errorEl.hidden = false;
    if (grid) grid.innerHTML = "";
  }

  async function loadReport() {
    const params = new URLSearchParams(window.location.search);
    const client = params.get("client") || "demo";
    const targetUrl = `https://${client}.lumerank.fr`;

    const clientNameEl = document.getElementById("client-name");
    const targetUrlEl = document.getElementById("target-url");
    if (clientNameEl) clientNameEl.textContent = formatClientName(client);
    if (targetUrlEl) targetUrlEl.textContent = targetUrl;

    const apiUrl = `https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=${encodeURIComponent(
      targetUrl
    )}&strategy=mobile&category=performance&category=accessibility&category=best-practices&category=seo&key=AIzaSyBS2lN1DAzFuUw1KgRSVLbVKuq19WUlV3M`;

    try {
      const res = await fetch(apiUrl);
      if (!res.ok) throw new Error(`PageSpeed API error: ${res.status}`);
      const data = await res.json();

      const categories = data?.lighthouseResult?.categories;
      const audits = data?.lighthouseResult?.audits;

      console.log(categories);

      if (!categories) throw new Error("Missing categories in response");

      const performance = Math.round((categories.performance?.score ?? 0) * 100);
      const accessibility = Math.round((categories.accessibility?.score ?? 0) * 100);
      const bestPractices = Math.round((categories["best-practices"]?.score ?? 0) * 100);
      const seo = Math.round((categories.seo?.score ?? 0) * 100);

      const grid = document.getElementById("score-grid");
      if (grid) {
        grid.innerHTML =
          buildScoreCard("Performance", performance) +
          buildScoreCard("Accessibilité", accessibility) +
          buildScoreCard("Bonnes pratiques", bestPractices) +
          buildScoreCard("SEO", seo);
      }

      const interactiveEl = document.getElementById("metric-interactive");
      const fcpEl = document.getElementById("metric-fcp");
      const siEl = document.getElementById("metric-si");

      if (interactiveEl) interactiveEl.textContent = audits?.interactive?.displayValue ?? "—";
      if (fcpEl) fcpEl.textContent = audits?.["first-contentful-paint"]?.displayValue ?? "—";
      if (siEl) siEl.textContent = audits?.["speed-index"]?.displayValue ?? "—";

      const comparisonFill = document.getElementById("comparison-fill");
      const comparisonScore = document.getElementById("comparison-score");
      if (comparisonFill) (comparisonFill as HTMLElement).style.width = `${performance}%`;
      if (comparisonScore) comparisonScore.textContent = `${performance}/100`;

      hideLoader();
      finishProgressBar();
    } catch (err) {
      console.error(err);
      showError();
    }
  }

  function setupViewApercuButtons() {
    const buttons = document.querySelectorAll(".js-view-apercu");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const client = new URLSearchParams(window.location.search).get("client");
        window.open("https://" + client + ".lumerank.fr", "_blank");
      });
    });
  }

  loadReport();
  setupViewApercuButtons();
</script>
